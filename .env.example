# ──────────────────────────────────────────────
# Momentum Breakout Bot — Environment Variables
# Optimised for Degen Claw weekly competitions.
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env to version control.
# ──────────────────────────────────────────────

# ── DegenClaw ACP ──────────────────────────────
LITE_AGENT_API_KEY=your_acp_api_key_here

# ── Telegram ──────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Trading parameters ─────────────────────────
SYMBOL=SOL
LEVERAGE=15
POSITION_SIZE_USD=50
CANDLE_INTERVAL=1h

# ── Strategy tuning (defaults are competition-optimised) ──
BREAKOUT_LOOKBACK=12
ROC_THRESHOLD=1.0
VOLUME_MULTIPLIER=1.0
TREND_EMA_PERIOD=50
ATR_MULTIPLIER=2.0
REWARD_RISK_RATIO=2.5

# ── Bot behaviour ──────────────────────────────
DRY_RUN=true
STATE_FILE=position_state.json

# ── Upstash Redis (recommended for Railway) ────
UPSTASH_REDIS_REST_URL=https://your-db-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
