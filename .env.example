# ──────────────────────────────────────────────
# VWAP Cross Trading Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env to version control.
# ──────────────────────────────────────────────

# ── Hyperliquid ────────────────────────────────
# Your wallet's private key (hex, without 0x prefix is fine)
HYPERLIQUID_PRIVATE_KEY=your_private_key_here

# ── Telegram ──────────────────────────────────
# Create a bot via @BotFather and get the token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Get your chat ID by messaging @userinfobot
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Trading parameters ─────────────────────────
# Trading symbol (coin name on Hyperliquid)
SYMBOL=BTC

# Leverage multiplier (1–50)
LEVERAGE=10

# Notional USD size per trade (position exposure = SIZE * LEVERAGE)
POSITION_SIZE_USD=50

# ── Bot behaviour ──────────────────────────────
# DRY_RUN=true  → Paper trade mode. Signals are computed and logged,
#                 Telegram alerts are sent, but NO real orders are placed.
# DRY_RUN=false → Live trading. Real orders will be sent to Hyperliquid.
#                 Only set to false when you're ready to trade real funds.
DRY_RUN=true

# Path to persist position state across bot restarts (local fallback)
STATE_FILE=position_state.json

# ── Upstash Redis (recommended for Railway deployments) ────────────────
# On Railway the local filesystem is wiped on every restart/redeploy, so
# position_state.json is lost.  Upstash Redis solves this: the bot stores
# position state in Redis via HTTP REST API and survives restarts safely.
#
# How to set up (free tier):
#   1. Create a free Redis database at https://console.upstash.com
#   2. Open the database → REST API tab
#   3. Copy the "UPSTASH_REDIS_REST_URL" and "UPSTASH_REDIS_REST_TOKEN" values
#   4. Paste them below (or add them as Railway environment variables)
#
# If these vars are left blank the bot falls back to STATE_FILE (local JSON).
UPSTASH_REDIS_REST_URL=https://your-db-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
